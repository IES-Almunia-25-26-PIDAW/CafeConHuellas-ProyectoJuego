[node name="Paragraph2" type="RichTextLabel" parent="FullContent" unique_id=1084844557]
custom_minimum_size = Vector2(900, 100)
layout_mode = 2
theme_override_colors/default_color = Color(0.05279708, 0.007995843, 0.007995843, 1)
theme_override_fonts/normal_font = ExtResource("2_3iesa")
theme_override_font_sizes/normal_font_size = 30
text = "De todas formas, su apertura es una noticia que ha alegrado mucho a nuestra comunidad, ¡estoy seguro de que se convertirá en mi nuevo lugar favorito para tomarme un cafelito!"
vertical_alignment = 1

[node name="Paragraph3" type="RichTextLabel" parent="FullContent" unique_id=2015443987]
custom_minimum_size = Vector2(900, 100)
layout_mode = 2
theme_override_colors/default_color = Color(0.05279708, 0.007995843, 0.007995843, 1)
theme_override_fonts/normal_font = ExtResource("2_3iesa")
theme_override_font_sizes/normal_font_size = 30
text = "Esperamos que este nuevo comienzo te sea todo un éxito y te sientas como en casa. Cualquier cosa puedes encontrarme en el ayuntamiento, ¡no te olvides de traerme un dulcecito o algo!"
vertical_alignment = 1

