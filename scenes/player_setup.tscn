[node name="Paragraph1" type="RichTextLabel" parent="FullContent" unique_id=2089966525]
custom_minimum_size = Vector2(900, 100)
layout_mode = 2
theme_override_colors/default_color = Color(0.05279708, 0.007995843, 0.007995843, 1)
theme_override_fonts/normal_font = ExtResource("2_3iesa")
theme_override_font_sizes/normal_font_size = 30
text = "Permíteme ser el primero en darte la bienvenida oficial a nuestro pequeño pueblo, Aínsa. Aunque no seamos muchos vecinos aquí, te aseguro que no te vas a aburrir."
